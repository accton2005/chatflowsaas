# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI GPT models.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# STRIPE_SECRET_KEY: Required for Stripe payments.
STRIPE_SECRET_KEY="MY_STRIPE_SECRET_KEY"

# STRIPE_WEBHOOK_SECRET: Required for Stripe webhooks.
STRIPE_WEBHOOK_SECRET="MY_STRIPE_WEBHOOK_SECRET"

# PAYPAL_CLIENT_ID: Required for PayPal payments.
PAYPAL_CLIENT_ID="MY_PAYPAL_CLIENT_ID"

# PAYPAL_CLIENT_SECRET: Required for PayPal payments.
PAYPAL_CLIENT_SECRET="MY_PAYPAL_CLIENT_SECRET"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
